---
import servicesData from '../data/services.json';

const { services } = servicesData;
---

<aside class="col-span-12 lg:col-span-2 flex flex-col gap-4 lg:overflow-hidden">
  <!-- Sobre Nosotros -->
  <div class="glass-panel p-4 lg:p-5 flex-none">
    <div
      class="text-xs text-primary mb-2 opacity-50 uppercase tracking-widest"
    >
      Sobre_Nosotros
    </div>
    <p class="text-xs text-slate-400 leading-relaxed">
      No somos una agencia de prompts.<br />
      Somos directores, creadores y productores<br />
      que han convertido la IA en su ventaja definitiva.
    </p>
    <p class="text-[11px] text-primary/50 mt-2 italic">
      Hacemos lo que antes no era posible.
    </p>
    <div class="mt-3 flex gap-3">
      <div class="text-[10px] px-2 py-1 border border-primary/20 text-primary/70">
        AI Cinema
      </div>
      <div class="text-[10px] px-2 py-1 border border-slate-800 text-slate-500">
        Barcelona
      </div>
      <div class="text-[10px] px-2 py-1 border border-slate-800 text-slate-500">
        Est. 2025
      </div>
    </div>
  </div>

  <!-- Servicios -->
  <div
    class="glass-panel p-4 lg:p-5 flex-1 flex flex-col gap-4 lg:overflow-y-auto scroll-hide"
  >
    <div
      class="text-xs text-primary opacity-50 uppercase tracking-widest"
    >
      Servicios
    </div>
    <div class="space-y-1">
      {services.map((service, i) => (
        <div
          class:list={[
            'service-item flex items-center gap-3 py-2 px-2',
            i === 0
              ? 'border-l-2 border-primary/40'
              : 'border-l-2 border-slate-700',
          ]}
          data-service-index={i}
        >
          <span
            class:list={[
              'material-symbols-outlined text-sm',
              i === 0 ? 'text-primary' : 'text-slate-500',
            ]}
          >
            {service.icon}
          </span>
          <div>
            <div class="text-xs font-bold text-slate-300">
              {service.title}
            </div>
            <div class="text-[10px] text-slate-600">{service.description}</div>
          </div>
        </div>
      ))}
    </div>

    <!-- Estado del estudio -->
    <div class="mt-4 pt-4 border-t border-panel-border">
      <div class="text-xs text-primary opacity-50 mb-3 uppercase">
        Studio_Status
      </div>
      <div class="space-y-3">
        <div>
          <div class="flex justify-between text-xs mb-1">
            <span class="text-slate-300">Proyectos en curso</span>
            <span class="text-primary font-bold">3</span>
          </div>
          <div class="h-[2px] bg-white/5 rounded-full overflow-hidden">
            <div
              class="h-full bg-primary progress-glow rounded-full w-[60%]"
            ></div>
          </div>
        </div>
        <div>
          <div class="flex justify-between text-xs mb-1">
            <span class="text-slate-300">Piezas entregadas</span>
            <span class="text-primary font-bold">24</span>
          </div>
          <div class="h-[2px] bg-white/5 rounded-full overflow-hidden">
            <div
              class="h-full bg-primary/70 progress-glow rounded-full w-[24%]"
            ></div>
          </div>
        </div>
        <div>
          <div class="flex justify-between text-xs mb-1">
            <span class="text-slate-300">Clientes activos</span>
            <span class="text-primary font-bold">7</span>
          </div>
          <div class="h-[2px] bg-white/5 rounded-full overflow-hidden">
            <div
              class="h-full bg-primary/50 progress-glow rounded-full w-[14%]"
            ></div>
          </div>
        </div>
      </div>
    </div>

    <!-- Feed IA en vivo -->
    <div class="mt-4 pt-4 border-t border-panel-border">
      <div class="text-xs text-primary opacity-50 mb-3 uppercase">
        AI_Generation_Live
      </div>
      <div class="space-y-2" id="aiFeed">
        <div class="text-[11px] border-l-2 border-primary/30 pl-2 py-1 bg-primary/5">
          <span class="text-primary/50">18:17</span>
          <span class="text-slate-300">Render 4K finalizado — NEON ODYSSEY</span>
        </div>
        <div class="text-[11px] border-l-2 border-primary/20 pl-2 py-1">
          <span class="text-primary/50">18:15</span>
          <span class="text-slate-300">Color grade exportado — ASCENSION</span>
        </div>
        <div class="text-[11px] border-l-2 border-slate-700 pl-2 py-1">
          <span class="text-slate-400">18:12</span>
          <span class="text-slate-300">Sesion de cliente iniciada</span>
        </div>
      </div>
    </div>
  </div>
</aside>

<script>
  if (!(window as any).__leftPanelInit) {
    (window as any).__leftPanelInit = true;

    const services = document.querySelectorAll('.service-item');
    let current = 0;
    setInterval(() => {
      services.forEach((s) => s.classList.remove('service-highlight'));
      services[current].classList.add('service-highlight');
      current = (current + 1) % services.length;
    }, 2500);

    const feedMessages = [
      { text: 'Render 4K finalizado — NEON ODYSSEY', level: 'high' },
      { text: 'Color grade exportado — ASCENSION', level: 'mid' },
      { text: 'Sesion de cliente iniciada', level: 'low' },
      { text: 'Generacion de frames IA — VOID FRAGMENTS', level: 'high' },
      { text: 'Composite VFX completo — CITY PULSE', level: 'mid' },
      { text: 'Audio master procesado — SIGNAL NOIR', level: 'mid' },
      { text: 'Upscale 8K completado', level: 'high' },
      { text: 'Pre-produccion iniciada — nuevo proyecto', level: 'low' },
      { text: 'Motion tracking finalizado', level: 'mid' },
      { text: 'Exportacion HDR — CHROME DREAMS', level: 'high' },
    ];

    const levelStyles = {
      high: { border: 'border-primary/30', bg: 'bg-primary/5', time: 'text-primary/50' },
      mid: { border: 'border-primary/20', bg: '', time: 'text-primary/50' },
      low: { border: 'border-slate-700', bg: '', time: 'text-slate-400' },
    };

    function feedNow() {
      const d = new Date();
      return `${String(d.getHours()).padStart(2, '0')}:${String(d.getMinutes()).padStart(2, '0')}`;
    }

    setInterval(() => {
      const feed = document.getElementById('aiFeed');
      if (!feed) return;
      const msg = feedMessages[Math.floor(Math.random() * feedMessages.length)];
      const style = levelStyles[msg.level as keyof typeof levelStyles];
      const div = document.createElement('div');
      div.className = `text-xs border-l-2 ${style.border} pl-2 py-1 ${style.bg}`;
      div.innerHTML = `<span class="${style.time}">${feedNow()}</span> <span class="text-slate-300">${msg.text}</span>`;
      feed.prepend(div);
      while (feed.children.length > 5) {
        feed.lastElementChild?.remove();
      }
    }, 7000);
  }
</script>
